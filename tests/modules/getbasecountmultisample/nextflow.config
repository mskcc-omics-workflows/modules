params {
    enable_conda = false
    fasta = "tools-test-dataset/getbasecountmultisample/reference/Homo_sapiens_assembly19.fasta"
    fastafai = "tools-test-dataset/getbasecountmultisample/reference/Homo_sapiens_assembly19.fasta.fai"
    bam = "tools-test-dataset/getbasecountmultisample/bam/C-9M47TU-L001-d_cl_aln_srt_MD_IR_FX_BR__aln_srt_IR_FX-duplex.bam"
    bambai = "tools-test-dataset/getbasecountmultisample/bam/C-9M47TU-L001-d_cl_aln_srt_MD_IR_FX_BR__aln_srt_IR_FX-duplex.bai"
    vcf = "tools-test-dataset/getbasecountmultisample/bam/C-9M47TU-L001-d.DONOR22-TP.vardict.vcf"
    fragment_count = 1
    filter_duplicate = 0
    maq = 20
    sample = "C-9M47TU-L001-d"
    outdir = "output"
}

process {

    publishDir = { "${params.outdir}/${task.process.tokenize(':')[-1].toLowerCase()}" }
    
}

profiles {
    debug { process.beforeScript = 'echo $HOSTNAME' }
    conda {
        params.enable_conda    = true
        docker.enabled         = false
        singularity.enabled    = false
        podman.enabled         = false
        shifter.enabled        = false
        charliecloud.enabled   = false
    }
    docker {
        docker.enabled = true
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        podman.enabled         = false
        shifter.enabled        = false
        charliecloud.enabled   = false
    }
}
